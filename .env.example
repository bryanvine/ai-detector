# ai-detector — copy to .env and fill in.

# LiteLLM gateway (ai-router). Key: mint a per-app virtual key via /key/generate.
ROUTER_BASE_URL=http://127.0.0.1:24001/v1
ROUTER_API_KEY=sk-...

# Models (must exist on the gateway). qwen3-30b-tq is the preferred open-weight scorer.
SCORING_MODEL=qwen3-30b-tq
SECONDARY_SCORING_MODEL=openai/gpt-oss-120b
JUDGE_MODEL=qwen3-30b-tq

# Image ML classifier (HuggingFace image-classification model).
IMAGE_ML_ENABLED=1
IMAGE_ML_MODEL=Organika/sdxl-detector
# Shared-GPU policy: use CUDA only when this much VRAM is free; evict when idle.
GPU_MIN_FREE_MB=2500
GPU_IDLE_EVICT_S=600

# Storage (analyses, uploads, feedback DB live here).
DATA_DIR=./data

# Web
HOST=127.0.0.1
PORT=27000
# Per-IP analyze requests per minute (protects the GPU backends).
RATE_LIMIT_PER_MIN=10
# Bearer token for GET /api/export.jsonl (training-data export). Empty = disabled.
EXPORT_TOKEN=
