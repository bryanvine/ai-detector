# ai-detector — copy to .env and fill in.

# Any OpenAI-compatible endpoint: vLLM directly, LiteLLM, Open WebUI, etc.
# Perplexity/rank signals additionally need vLLM-style prompt_logprobs
# (completions with echo=true) — see README. Leave the key empty if your
# endpoint doesn't require one.
ROUTER_BASE_URL=http://localhost:8000/v1
ROUTER_API_KEY=

# Models (ids as your endpoint exposes them). Open-weight examples shown.
SCORING_MODEL=qwen3-30b-tq
SECONDARY_SCORING_MODEL=openai/gpt-oss-120b
JUDGE_MODEL=qwen3-30b-tq

# Image ML classifier (HuggingFace image-classification model).
IMAGE_ML_ENABLED=1
IMAGE_ML_MODEL=Organika/sdxl-detector
# Fine-tuned video-frame checkpoint (training/README.md). Empty = capped
# image-model fallback for video frames.
VIDEO_FRAME_MODEL=
# Shared-GPU policy: use CUDA only when this much VRAM is free; evict when idle.
GPU_MIN_FREE_MB=2500
GPU_IDLE_EVICT_S=600

# Storage (analyses, uploads, feedback DB live here).
DATA_DIR=./data

# Web
HOST=127.0.0.1
PORT=8080
# Per-IP analyze requests per minute (protects your inference backend).
RATE_LIMIT_PER_MIN=10
# Bearer token for GET /api/export.jsonl (training-data export). Empty = disabled.
EXPORT_TOKEN=
